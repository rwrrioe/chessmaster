# API service (Railway: chessmaster-api)
POSTGRES_URL=postgres://user:pass@host:5432/db?sslmode=require
JWT_SECRET=<openssl rand -hex 32>
GEMINI_API_KEY=<google ai studio key>
GEMINI_MODEL=gemini-2.0-flash
PORT=8080
STOCKFISH_PATH=/usr/games/stockfish
CORS_ORIGINS=https://chessmaster-web.up.railway.app

# Frontend service (Railway: chessmaster-web) — used at BUILD time, not runtime
NEXT_PUBLIC_API_URL=https://chessmaster-api.up.railway.app
NEXT_PUBLIC_WS_URL=wss://chessmaster-api.up.railway.app
